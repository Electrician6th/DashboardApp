<Page x:Class="DashboardApp.View.Pages.FridgesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:DashboardApp.View.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="1280"
      Title="Морозильные камеры">

    <Grid>
        <ListBox Name="FridgesLb">
            <!-- Задаем внешний вид карточки-->
            <ListBox.ItemTemplate>
                <!--Шаблон карточки-->
                <DataTemplate>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="50"/>
                            <RowDefinition Height="5"/>
                            <RowDefinition Height="50"/>
                            <RowDefinition Height="5"/>
                            <RowDefinition Height="50"/>
                            <RowDefinition Height="5"/>
                            <RowDefinition Height="50"/>
                            <RowDefinition Height="5"/>
                            <RowDefinition Height="50"/>
                            <RowDefinition Height="5"/>
                            <RowDefinition Height="50"/>
                            <RowDefinition Height="5"/>
                            <RowDefinition Height="50"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Склад"/>
                        <TextBlock Grid.Row="2" Text="Описание"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            

                            <ProgressBar Grid.Column="0" Value="50" Minimum="0" Maximum="100"/>
                            <TextBlock Grid.Column="2" Text="50%"/>
                        </Grid>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
            <!--Задаем расположение карточек -->
            <ListBox.ItemsPanel>
                <!--Задаем шаблон расположения -->
                <ItemsPanelTemplate>
                    <UniformGrid Columns="2">
                        
                    </UniformGrid>
                </ItemsPanelTemplate>
                
            </ListBox.ItemsPanel>
        </ListBox>
    </Grid>
</Page>
