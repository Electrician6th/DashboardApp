<Page x:Class="DashboardApp.View.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:DashboardApp.View.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="614" d:DesignWidth="1280"
      Title="Дашборд">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <Border BorderThickness="1" BorderBrush="Black" CornerRadius="15">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Name="FridgeCountTbl" Text=" 10" FontSize="80" FontWeight="SemiBold" TextAlignment="Center"/>
                <TextBlock Text="Морозильных аппаратов"  FontSize="20"/>
            </StackPanel>
        </Border>
        <Border BorderThickness="2" BorderBrush="Black" CornerRadius="15" Grid.Column="4" Margin="0,0,0,20" Grid.RowSpan="2">
            <Grid VerticalAlignment="Top" Margin="-8,32,8,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="5"/>
                    <RowDefinition Height="1*"/>
                </Grid.RowDefinitions>

                <TextBlock x:Name="WarehousesCountTbl2" FontSize="60" FontWeight="SemiBold"
                    HorizontalAlignment="Center"><Run Language="ru-ru" Text="25"/></TextBlock>
                <TextBlock
            Grid.Row="2" HorizontalAlignment="Center" FontSize="25" FontWeight="SemiBold"><Run Language="ru-ru" Text="поставщиков"/></TextBlock>

                <TextBlock Grid.Row="2"  Text="складов" FontSize="25"
                    FontWeight="SemiBold"
                    HorizontalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Page>
