<Page x:Class="DashboardApp.View.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:DashboardApp.View.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="614" d:DesignWidth="1280"
      Title="Дашборд">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>
            <!--Количество морозильных камер-->
        <Border BorderThickness="1" Padding="20" Background="LightSkyBlue" CornerRadius="15">
            <StackPanel HorizontalAlignment="Center"  VerticalAlignment="Center">
                <TextBlock Name="FridgeCountTbl" Text="5" FontSize="50" FontWeight="SemiBold" TextAlignment="Center"/>
                <TextBlock Text="Морозильных аппаратов"  FontSize="20"/>
            </StackPanel>
        </Border>
        <!--Количество поставщиков-->
        <Border BorderThickness="2" Padding="20" Background="LightGreen" CornerRadius="15" Grid.Column="2">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Name="SupplierCountTbl" Text="5" FontSize="50" FontWeight="SemiBold" TextAlignment="Center"/>
                <TextBlock Text="Поставщиков" FontSize="20"/>
            </StackPanel>
        </Border>
        <!--Количество товаров-->
        <Border BorderThickness="2" Padding="20" Background="LightCyan" CornerRadius="15" Grid.Column="4">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Name="ProductCountTbl" Text="10" FontSize="50" FontWeight="SemiBold" TextAlignment="Center"/>
                <TextBlock Text="Товаров" FontSize="20"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
