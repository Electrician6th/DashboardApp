<Page x:Class="DashboardApp.View.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:DashboardApp.View.Pages"
      xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
      mc:Ignorable="d" 
      d:DesignHeight="614" d:DesignWidth="1280"
      Title="Дашборд">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>
        
        <Expander Header="Общая статистика" FontSize="20">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <!--Количество морозильных камер-->
                <Border BorderThickness="1" Padding="20" Background="LightSkyBlue" CornerRadius="15">
                    <StackPanel HorizontalAlignment="Center"  VerticalAlignment="Center">
                        <TextBlock Name="FridgeCountTbl" Text="5" FontSize="50" FontWeight="SemiBold" TextAlignment="Center"/>
                        <TextBlock Text="Морозильных аппаратов"  FontSize="20"/>
                    </StackPanel>
                </Border>

                <!--Количество поставщиков-->
                <Border BorderThickness="2" Padding="20" Background="LightSkyBlue" CornerRadius="15" Grid.Column="4">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Name="SupplierCountTbl" Text="5" FontSize="50" FontWeight="SemiBold" TextAlignment="Center"/>
                        <TextBlock Text="Поставщиков" FontSize="20"/>
                    </StackPanel>

                </Border>

                <!--Количество товаров-->
                <Border BorderThickness="2" Padding="20" Background="LightCyan" CornerRadius="15" Grid.Column="2">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Name="ProductCountTbl" Text="10" FontSize="50" FontWeight="SemiBold" TextAlignment="Center"/>
                        <TextBlock Text="Товаров" FontSize="20"/>
                    </StackPanel>
                </Border>

            </Grid>
        </Expander>

        <Expander Header="Объем морозильных камер" Grid.Row="2" FontSize="20">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>
                
                <!--Весь доступный обьем-->
                <Border BorderThickness="1" CornerRadius="15" Grid.Column="0" Background="BlanchedAlmond" Padding="20">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" >
                        <TextBlock Name="GeneralCountTbl" Text=" 650 л" FontSize="50" FontWeight="SemiBold" TextAlignment="Center"/>
                        <TextBlock Text="Общий доступный обьем" HorizontalAlignment="Center" FontSize="20"/>
                    </StackPanel>
                </Border>

                <!--Занято-->
                <Border BorderThickness="1" CornerRadius="15" Grid.Column="2" Background="PaleTurquoise" Padding="20">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Name="BusyCountTbl" Text="  406 л" FontSize="50" FontWeight="SemiBold" TextAlignment="Center"/>
                        <TextBlock Text="Занято" HorizontalAlignment="Center" FontSize="20"/>
                    </StackPanel>
                </Border>

                <!--Свободно-->
                <Border BorderThickness="1" CornerRadius="15" Grid.Column="4" Background="Lavender" Padding="20">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Name="FreeCountTbl" Text=" 244 л" FontSize="50" FontWeight="SemiBold" TextAlignment="Center"/>
                        <TextBlock Text="Свободно" HorizontalAlignment="Center" FontSize="20"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Expander>
        <Expander Header="Накладные" Grid.Row="4" FontSize="20">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <!--Кол-во накладных за текущий год-->
                <Border BorderThickness="1" CornerRadius="15" Grid.Column="0" Background="LightCyan" Padding="20">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Name="CurrentYearReceioTbl" Text="5" FontSize="50" FontWeight="SemiBold" TextAlignment="Center"/>
                        <TextBlock Text="в теущем году" TextWrapping="Wrap" TextAlignment="Center" FontSize="20"/>
                    </StackPanel>
                </Border>
                <!--Среднее кол-во товаров в накладной-->
                <Border BorderThickness="1" CornerRadius="15" Grid.Column="2" Background="LightCyan" Padding="20">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Name="AverageProductInReceiptTBl" Text="15" FontSize="50" FontWeight="SemiBold" TextAlignment="Center"/>
                        <TextBlock Text="товаров в накладной (среднее)" TextWrapping="Wrap" TextAlignment="Center" FontSize="20"/>
                    </StackPanel>
                </Border>
                
                <!--Общее кол-во товаров в накладной-->
                <Border BorderThickness="1" CornerRadius="15" Grid.Column="4" Background="LightCyan" Padding="20">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Name="ProductInReceiptTBl" Text="120" FontSize="50" FontWeight="SemiBold" TextAlignment="Center"/>
                        <TextBlock Text="товаров в накладной" TextWrapping="Wrap" TextAlignment="Center" FontSize="20"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Expander>

        <Expander Grid.Row="6" Header="Затраты по поставщикам">
            <Grid>
                <lvc:CartesianChart Name="Chart" ZoomMode="None">
                    
                </lvc:CartesianChart>
            </Grid>
        </Expander>

    </Grid>
</Page>
